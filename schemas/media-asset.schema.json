{
“$schema”: “https://json-schema.org/draft/2020-12/schema”,
“$id”: “https://example.com/schemas/media-asset.schema.json”,
“title”: “Media Asset Schema”,
“description”: “Schema for reusable storefront media assets inside store-os”,
“type”: “object”,
“additionalProperties”: false,
“required”: [
“asset_id”,
“asset_type”,
“source_type”,
“usage_role”,
“title”,
“status”,
“allowed_pages”,
“seo_role”,
“performance_risk”
],
“properties”: {
“asset_id”: {
“type”: “string”,
“minLength”: 1,
“pattern”: “^[a-z0-9-]+$”
},
“asset_type”: {
“type”: “string”,
“enum”: [
“image”,
“video”,
“embed”,
“icon”,
“animation”,
“poster”,
“mixed-media”
]
},
“source_type”: {
“type”: “string”,
“enum”: [
“uploaded”,
“generated-ai”,
“external-embed”,
“supplier”,
“edited-derived”,
“other”
]
},
“usage_role”: {
“type”: “string”,
“enum”: [
“hero”,
“product-gallery”,
“collection-support”,
“storytelling”,
“comparison”,
“trust-support”,
“editorial”,
“background”,
“iconography”,
“other”
]
},
“title”: {
“type”: “string”,
“minLength”: 1
},
“alt_text”: {
“type”: “string”
},
“caption”: {
“type”: “string”
},
“status”: {
“type”: “string”,
“enum”: [
“draft”,
“approved”,
“rejected”,
“archived”
]
},
“allowed_pages”: {
“type”: “array”,
“minItems”: 1,
“items”: {
“type”: “string”,
“enum”: [
“homepage”,
“product-page”,
“collection-page”,
“page”,
“article”,
“blog-index”,
“cart”
]
}
},
“fallback_required”: {
“type”: “boolean”
},
“fallback_asset_id”: {
“type”: “string”,
“pattern”: “^[a-z0-9-]+$”
},
“mobile_fallback_required”: {
“type”: “boolean”
},
“mobile_fallback_asset_id”: {
“type”: “string”,
“pattern”: “^[a-z0-9-]+$”
},
“autoplay”: {
“type”: “boolean”
},
“muted”: {
“type”: “boolean”
},
“loop”: {
“type”: “boolean”
},
“lazy_load”: {
“type”: “boolean”
},
“poster_asset_id”: {
“type”: “string”,
“pattern”: “^[a-z0-9-]+$”
},
“seo_role”: {
“type”: “string”,
“enum”: [
“decorative”,
“supporting”,
“index-relevant”,
“answer-supporting”
]
},
“entity_support”: {
“type”: “string”,
“enum”: [
“none”,
“brand”,
“product”,
“category”,
“mixed”
]
},
“performance_risk”: {
“type”: “string”,
“enum”: [
“low”,
“medium”,
“high”
]
},
“compliance_notes”: {
“type”: “string”
},
“notes”: {
“type”: “string”
}
}
}
