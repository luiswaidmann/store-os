{
"$schema": "https://json-schema.org/draft/2020-12/schema",
"$id": "https://example.com/schemas/market-intelligence.schema.json",
"title": "Market Intelligence Schema",
"description": "Schema for market, audience, search, and positioning intelligence inside store-os",
"type": "object",
"additionalProperties": false,
"required": [
"market_category",
"audience_segments",
"core_problems",
"purchase_motivators",
"search_intents",
"trust_factors",
"competitor_types",
"positioning_goals"
],
"properties": {
"market_category": {
"type": "string",
"minLength": 1
},
"market_subcategories": {
"type": "array",
"items": {
"type": "string",
"minLength": 1
}
},
"audience_segments": {
"type": "array",
"minItems": 1,
"items": {
"type": "object",
"additionalProperties": false,
"required": [
"segment_name",
"description",
"purchase_drivers"
],
"properties": {
"segment_name": {
"type": "string",
"minLength": 1
},
"description": {
"type": "string",
"minLength": 1
},
"purchase_drivers": {
"type": "array",
"minItems": 1,
"items": {
"type": "string",
"minLength": 1
}
},
"barriers": {
"type": "array",
"items": {
"type": "string",
"minLength": 1
}
}
}
}
},
"core_problems": {
"type": "array",
"minItems": 1,
"items": {
"type": "string",
"minLength": 1
}
},
"purchase_motivators": {
"type": "array",
"minItems": 1,
"items": {
"type": "string",
"minLength": 1
}
},
"search_intents": {
"type": "array",
"minItems": 1,
"items": {
"type": "object",
"additionalProperties": false,
"required": [
"intent_type",
"description"
],
"properties": {
"intent_type": {
"type": "string",
"enum": [
"informational",
"commercial",
"transactional",
"navigational",
"comparison"
]
},
"description": {
"type": "string",
"minLength": 1
},
"example_queries": {
"type": "array",
"items": {
"type": "string",
"minLength": 1
}
}
}
}
},
"trust_factors": {
"type": "array",
"minItems": 1,
"items": {
"type": "string",
"minLength": 1
}
},
"competitor_types": {
"type": "array",
"minItems": 1,
"items": {
"type": "object",
"additionalProperties": false,
"required": [
"type_name",
"description"
],
"properties": {
"type_name": {
"type": "string",
"minLength": 1
},
"description": {
"type": "string",
"minLength": 1
},
"strengths": {
"type": "array",
"items": {
"type": "string",
"minLength": 1
}
},
"weaknesses": {
"type": "array",
"items": {
"type": "string",
"minLength": 1
}
}
}
}
},
"positioning_goals": {
"type": "array",
"minItems": 1,
"items": {
"type": "string",
"minLength": 1
}
},
"content_opportunities": {
"type": "array",
"items": {
"type": "string",
"minLength": 1
}
},
"media_opportunities": {
"type": "array",
"items": {
"type": "string",
"minLength": 1
}
},
"seo_considerations": {
"type": "array",
"items": {
"type": "string",
"minLength": 1
}
},
"aeo_considerations": {
"type": "array",
"items": {
"type": "string",
"minLength": 1
}
},
"notes": {
"type": "string"
},
"market_hypotheses": {
"type": "array",
"items": {
"type": "object",
"required": ["hypothesis", "evidence_basis", "confidence"],
"properties": {
"hypothesis": { "type": "string" },
"evidence_basis": { "type": "string" },
"confidence": {
"type": "string",
"enum": ["high", "medium", "low", "speculative"]
},
"risk_if_wrong": { "type": "string" }
}
}
},
"trend_signals": {
"type": "array",
"items": {
"type": "object",
"required": ["trend_name", "direction"],
"properties": {
"trend_name": { "type": "string" },
"direction": {
"type": "string",
"enum": ["growing", "stable", "declining", "unknown"]
},
"relevance_to_store": { "type": "string" },
"confidence": {
"type": "string",
"enum": ["high", "medium", "low", "speculative"]
}
}
}
},
"seasonality_hints": {
"type": "array",
"items": {
"type": "object",
"properties": {
"period": { "type": "string" },
"demand_pattern": { "type": "string" },
"relevance": { "type": "string" }
}
}
},
"price_band_logic": {
"type": "object",
"properties": {
"low_end_signal": { "type": "string" },
"mid_market_signal": { "type": "string" },
"premium_signal": { "type": "string" },
"store_positioning_fit": { "type": "string" }
}
},
"risk_flags": {
"type": "array",
"items": {
"type": "object",
"properties": {
"flag_type": { "type": "string" },
"description": { "type": "string" },
"severity": {
"type": "string",
"enum": ["high", "medium", "low"]
}
}
}
},
"opportunity_flags": {
"type": "array",
"items": {
"type": "object",
"properties": {
"opportunity_type": { "type": "string" },
"description": { "type": "string" },
"confidence": {
"type": "string",
"enum": ["high", "medium", "low", "speculative"]
}
}
}
},
"competition_surface": {
"type": "object",
"properties": {
"intensity": {
"type": "string",
"enum": ["low", "medium", "high", "fragmented"]
},
"key_battlegrounds": {
"type": "array",
"items": { "type": "string" }
},
"differentiation_whitespace": {
"type": "array",
"items": { "type": "string" }
}
}
},
"adjacent_market_hints": {
"type": "array",
"items": { "type": "string" }
},
"unknown_states": {
"type": "array",
"items": {
"type": "object",
"properties": {
"topic": { "type": "string" },
"why_unknown": { "type": "string" },
"impact_on_planning": { "type": "string" }
}
}
},
"_meta": {
"type": "object",
"description": "Optional artifact metadata envelope"
}
}
}
