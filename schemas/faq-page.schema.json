{
“$schema”: “https://json-schema.org/draft/2020-12/schema”,
“$id”: “https://example.com/schemas/faq-page.schema.json”,
“title”: “FAQ Page Schema”,
“description”: “Schema for dedicated FAQ page content inside store-os”,
“type”: “object”,
“additionalProperties”: false,
“required”: [
“page_title”,
“page_goal”,
“intro_text”,
“faq_groups”,
“trust_role”,
“cta_direction”
],
“properties”: {
“page_title”: {
“type”: “string”,
“minLength”: 1
},
“page_goal”: {
“type”: “string”,
“enum”: [
“support-reduction”,
“trust-building”,
“purchase-support”,
“hybrid”
]
},
“intro_text”: {
“type”: “string”,
“minLength”: 1
},
“faq_groups”: {
“type”: “array”,
“minItems”: 1,
“items”: {
“type”: “object”,
“additionalProperties”: false,
“required”: [
“group_name”,
“questions”
],
“properties”: {
“group_name”: {
“type”: “string”,
“minLength”: 1
},
“questions”: {
“type”: “array”,
“minItems”: 1,
“items”: {
“type”: “object”,
“additionalProperties”: false,
“required”: [
“question”,
“answer”,
“question_type”
],
“properties”: {
“question”: {
“type”: “string”,
“minLength”: 1
},
“answer”: {
“type”: “string”,
“minLength”: 1
},
“question_type”: {
“type”: “string”,
“enum”: [
“product”,
“category”,
“shipping”,
“returns”,
“trust”,
“compatibility”,
“care”,
“payment”,
“support”,
“general”
]
},
“internal_link_target_type”: {
“type”: “string”,
“enum”: [
“none”,
“product-page”,
“collection-page”,
“guide-page”,
“contact-page”,
“homepage”
]
}
}
}
}
}
}
},
“trust_role”: {
“type”: “string”,
“enum”: [
“light”,
“balanced”,
“strong”
]
},
“media_notes”: {
“type”: “array”,
“items”: {
“type”: “string”,
“minLength”: 1
}
},
“cta_direction”: {
“type”: “object”,
“additionalProperties”: false,
“required”: [
“primary_cta”,
“cta_tone”
],
“properties”: {
“primary_cta”: {
“type”: “string”,
“enum”: [
“none”,
“contact-support”,
“shop-now”,
“explore-products”,
“learn-more”,
“mixed”
]
},
“cta_tone”: {
“type”: “string”,
“enum”: [
“subtle”,
“balanced”,
“assertive”
]
}
}
},
“notes”: {
“type”: “string”
}
}
}
