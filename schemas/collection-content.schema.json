{
“$schema”: “https://json-schema.org/draft/2020-12/schema”,
“$id”: “https://example.com/schemas/collection-content.schema.json”,
“title”: “Collection Content Schema”,
“description”: “Schema for high-quality collection page content inside store-os”,
“type”: “object”,
“additionalProperties”: false,
“required”: [
“collection_title”,
“collection_subtitle”,
“category_promise”,
“intro_text”,
“category_summary”,
“selection_guidance”,
“trust_elements”,
“faq_items”,
“cta_direction”
],
“properties”: {
“collection_title”: {
“type”: “string”,
“minLength”: 1
},
“collection_subtitle”: {
“type”: “string”,
“minLength”: 1
},
“category_promise”: {
“type”: “string”,
“minLength”: 1
},
“intro_text”: {
“type”: “string”,
“minLength”: 1
},
“category_summary”: {
“type”: “string”,
“minLength”: 1
},
“selection_guidance”: {
“type”: “array”,
“minItems”: 1,
“items”: {
“type”: “object”,
“additionalProperties”: false,
“required”: [
“guidance_title”,
“guidance_text”
],
“properties”: {
“guidance_title”: {
“type”: “string”,
“minLength”: 1
},
“guidance_text”: {
“type”: “string”,
“minLength”: 1
}
}
}
},
“category_highlights”: {
“type”: “array”,
“items”: {
“type”: “string”,
“minLength”: 1
}
},
“comparison_notes”: {
“type”: “array”,
“items”: {
“type”: “string”,
“minLength”: 1
}
},
“trust_elements”: {
“type”: “array”,
“minItems”: 1,
“items”: {
“type”: “string”,
“minLength”: 1
}
},
“faq_items”: {
“type”: “array”,
“minItems”: 1,
“items”: {
“type”: “object”,
“additionalProperties”: false,
“required”: [
“question”,
“answer”
],
“properties”: {
“question”: {
“type”: “string”,
“minLength”: 1
},
“answer”: {
“type”: “string”,
“minLength”: 1
}
}
}
},
“internal_navigation_hints”: {
“type”: “array”,
“items”: {
“type”: “string”,
“minLength”: 1
}
},
“cta_direction”: {
“type”: “object”,
“additionalProperties”: false,
“required”: [
“primary_cta”,
“cta_tone”
],
“properties”: {
“primary_cta”: {
“type”: “string”,
“enum”: [
“shop-now”,
“explore-products”,
“compare-options”,
“learn-more”,
“mixed”
]
},
“cta_tone”: {
“type”: “string”,
“enum”: [
“subtle”,
“balanced”,
“assertive”
]
}
}
},
“notes”: {
“type”: “string”
}
}
}

