{
"$schema": "https://json-schema.org/draft/2020-12/schema",
"$id": "https://example.com/schemas/product-content.schema.json",
"title": "Product Content Schema",
"description": "Schema for high-quality product page content inside store-os",
"type": "object",
"additionalProperties": false,
"required": [
"product_title",
"product_subtitle",
"primary_promise",
"short_description",
"benefit_bullets",
"feature_blocks",
"use_cases",
"objection_handling",
"trust_elements",
"faq_items",
"cta_direction"
],
"properties": {
"product_title": {
"type": "string",
"minLength": 1
},
"product_subtitle": {
"type": "string",
"minLength": 1
},
"primary_promise": {
"type": "string",
"minLength": 1
},
"short_description": {
"type": "string",
"minLength": 1
},
"benefit_bullets": {
"type": "array",
"minItems": 3,
"items": {
"type": "string",
"minLength": 1
}
},
"feature_blocks": {
"type": "array",
"minItems": 1,
"items": {
"type": "object",
"additionalProperties": false,
"required": [
"feature_name",
"feature_description",
"customer_benefit"
],
"properties": {
"feature_name": {
"type": "string",
"minLength": 1
},
"feature_description": {
"type": "string",
"minLength": 1
},
"customer_benefit": {
"type": "string",
"minLength": 1
}
}
}
},
"use_cases": {
"type": "array",
"minItems": 1,
"items": {
"type": "string",
"minLength": 1
}
},
"objection_handling": {
"type": "array",
"minItems": 1,
"items": {
"type": "object",
"additionalProperties": false,
"required": [
"objection",
"response"
],
"properties": {
"objection": {
"type": "string",
"minLength": 1
},
"response": {
"type": "string",
"minLength": 1
}
}
}
},
"trust_elements": {
"type": "array",
"minItems": 1,
"items": {
"type": "string",
"minLength": 1
}
},
"faq_items": {
"type": "array",
"minItems": 1,
"items": {
"type": "object",
"additionalProperties": false,
"required": [
"question",
"answer"
],
"properties": {
"question": {
"type": "string",
"minLength": 1
},
"answer": {
"type": "string",
"minLength": 1
}
}
}
},
"comparison_notes": {
"type": "array",
"items": {
"type": "string",
"minLength": 1
}
},
"care_instructions": {
"type": "string"
},
"shipping_notes": {
"type": "string"
},
"returns_notes": {
"type": "string"
},
"cta_direction": {
"type": "object",
"additionalProperties": false,
"required": [
"primary_cta",
"cta_tone"
],
"properties": {
"primary_cta": {
"type": "string",
"enum": [
"buy-now",
"add-to-cart",
"learn-more",
"choose-variant",
"mixed"
]
},
"cta_tone": {
"type": "string",
"enum": [
"subtle",
"balanced",
"assertive"
]
}
}
},
"notes": {
"type": "string"
}
}
}
