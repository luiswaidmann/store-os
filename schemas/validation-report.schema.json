{
“$schema”: “https://json-schema.org/draft/2020-12/schema”,
“$id”: “https://example.com/schemas/validation-report.schema.json”,
“title”: “Validation Report Schema”,
“description”: “Schema for validation results, failures, warnings, and publish blocking signals inside store-os”,
“type”: “object”,
“additionalProperties”: false,
“required”: [
“report_id”,
“project_id”,
“store_id”,
“environment”,
“generated_at”,
“overall_status”,
“checks”,
“summary”
],
“properties”: {
“report_id”: {
“type”: “string”,
“minLength”: 1,
“pattern”: “^[a-z0-9-]+$”
},
“project_id”: {
“type”: “string”,
“minLength”: 1,
“pattern”: “^[a-z0-9-]+$”
},
“store_id”: {
“type”: “string”,
“minLength”: 1,
“pattern”: “^[a-z0-9-]+$”
},
“environment”: {
“type”: “string”,
“enum”: [
“draft”,
“staging”,
“production”
]
},
“generated_at”: {
“type”: “string”,
“format”: “date-time”
},
“overall_status”: {
“type”: “string”,
“enum”: [
“passed”,
“passed-with-warnings”,
“failed”,
“blocked”
]
},
“checks”: {
“type”: “array”,
“minItems”: 1,
“items”: {
“type”: “object”,
“additionalProperties”: false,
“required”: [
“check_name”,
“status”,
“severity”
],
“properties”: {
“check_name”: {
“type”: “string”,
“minLength”: 1
},
“status”: {
“type”: “string”,
“enum”: [
“passed”,
“warning”,
“failed”,
“skipped”
]
},
“severity”: {
“type”: “string”,
“enum”: [
“low”,
“medium”,
“high”,
“critical”
]
},
“scope”: {
“type”: “string”,
“enum”: [
“theme”,
“content”,
“seo”,
“aeo”,
“media”,
“performance”,
“accessibility”,
“deployment”,
“project-structure”,
“other”
]
},
“details”: {
“type”: “string”
},
“recommended_action”: {
“type”: “string”
},
“blocking”: {
“type”: “boolean”
}
}
}
},
“summary”: {
“type”: “object”,
“additionalProperties”: false,
“required”: [
“passed_count”,
“warning_count”,
“failed_count”,
“blocking_count”,
“manual_review_required”,
“publish_blocked”
],
“properties”: {
“passed_count”: {
“type”: “integer”,
“minimum”: 0
},
“warning_count”: {
“type”: “integer”,
“minimum”: 0
},
“failed_count”: {
“type”: “integer”,
“minimum”: 0
},
“blocking_count”: {
“type”: “integer”,
“minimum”: 0
},
“manual_review_required”: {
“type”: “boolean”
},
“publish_blocked”: {
“type”: “boolean”
}
}
},
“notes”: {
“type”: “string”
}
}
}
