{
"$schema": "https://json-schema.org/draft/2020-12/schema",
"$id": "https://example.com/schemas/seo-strategy.schema.json",
"title": "SEO Strategy Schema",
"description": "Schema for store-level SEO strategy inside store-os",
"type": "object",
"additionalProperties": false,
"required": [
"strategy_name",
"primary_seo_goal",
"keyword_focus",
"content_depth",
"page_priority",
"internal_linking_strategy",
"collection_seo_role",
"product_seo_role",
"knowledge_seo_role",
"technical_seo_priority"
],
"properties": {
"strategy_name": {
"type": "string",
"minLength": 1
},
"primary_seo_goal": {
"type": "string",
"enum": [
"transactional-growth",
"category-discovery",
"brand-plus-category-growth",
"knowledge-plus-commerce",
"hybrid"
]
},
"keyword_focus": {
"type": "object",
"additionalProperties": false,
"required": [
"primary_keyword_type",
"secondary_keyword_type"
],
"properties": {
"primary_keyword_type": {
"type": "string",
"enum": [
"brand",
"category",
"problem-solution",
"product-type",
"comparison",
"mixed"
]
},
"secondary_keyword_type": {
"type": "string",
"enum": [
"brand",
"category",
"problem-solution",
"product-type",
"comparison",
"mixed"
]
},
"long_tail_priority": {
"type": "string",
"enum": [
"low",
"medium",
"high"
]
}
}
},
"content_depth": {
"type": "string",
"enum": [
"light",
"balanced",
"deep"
]
},
"page_priority": {
"type": "array",
"minItems": 1,
"items": {
"type": "string",
"enum": [
"homepage",
"product-pages",
"collection-pages",
"guide-pages",
"faq-pages",
"blog-articles"
]
}
},
"internal_linking_strategy": {
"type": "object",
"additionalProperties": false,
"required": [
"link_depth",
"cross_linking_intensity"
],
"properties": {
"link_depth": {
"type": "string",
"enum": [
"simple",
"balanced",
"rich"
]
},
"cross_linking_intensity": {
"type": "string",
"enum": [
"low",
"medium",
"high"
]
},
"knowledge_to_commerce_links": {
"type": "boolean"
}
}
},
"collection_seo_role": {
"type": "string",
"enum": [
"light-support",
"balanced-driver",
"primary-driver"
]
},
"product_seo_role": {
"type": "string",
"enum": [
"light-support",
"balanced-driver",
"primary-driver"
]
},
"knowledge_seo_role": {
"type": "string",
"enum": [
"none",
"supporting",
"balanced",
"major"
]
},
"technical_seo_priority": {
"type": "object",
"additionalProperties": false,
"required": [
"performance_priority",
"crawl_clarity_priority",
"indexation_control_priority"
],
"properties": {
"performance_priority": {
"type": "string",
"enum": [
"medium",
"high",
"critical"
]
},
"crawl_clarity_priority": {
"type": "string",
"enum": [
"medium",
"high",
"critical"
]
},
"indexation_control_priority": {
"type": "string",
"enum": [
"medium",
"high",
"critical"
]
}
}
},
"structured_data_priority": {
"type": "array",
"items": {
"type": "string",
"enum": [
"product",
"faq",
"breadcrumb",
"article",
"review",
"item-list",
"organization"
]
}
},
"notes": {
"type": "string"
}
}
}
