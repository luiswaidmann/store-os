{
"$schema": "https://json-schema.org/draft/2020-12/schema",
"$id": "https://example.com/schemas/store-profile.schema.json",
"title": "Store Profile Schema",
"description": "Schema for a store profile inside store-os",
"type": "object",
"additionalProperties": false,
"required": [
"store_id",
"store_name",
"store_type",
"platform",
"business_model",
"primary_market",
"target_markets",
"primary_language",
"languages",
"primary_currency",
"currencies",
"vertical",
"price_positioning",
"catalog_type",
"brand_maturity",
"operating_mode"
],
"properties": {
"store_id": {
"type": "string",
"minLength": 1,
"pattern": "^[a-z0-9-]+$",
"description": "Unique store identifier using lowercase letters, numbers, and hyphens only"
},
"store_name": {
"type": "string",
"minLength": 1
},
"store_type": {
"type": "string",
"enum": [
"single-brand-store",
"multi-product-store",
"category-specialist",
"editorial-commerce-store",
"general-commerce-store"
]
},
"platform": {
"type": "string",
"enum": [
"shopify",
"woocommerce",
"custom",
"other"
]
},
"business_model": {
"type": "string",
"enum": [
"ecommerce",
"dropshipping",
"hybrid",
"other"
]
},
"primary_market": {
"type": "string",
"minLength": 2
},
"target_markets": {
"type": "array",
"minItems": 1,
"items": {
"type": "string",
"minLength": 2
}
},
"primary_language": {
"type": "string",
"minLength": 2
},
"languages": {
"type": "array",
"minItems": 1,
"items": {
"type": "string",
"minLength": 2
}
},
"primary_currency": {
"type": "string",
"minLength": 3,
"maxLength": 3
},
"currencies": {
"type": "array",
"minItems": 1,
"items": {
"type": "string",
"minLength": 3,
"maxLength": 3
}
},
"vertical": {
"type": "string",
"minLength": 1
},
"price_positioning": {
"type": "string",
"enum": [
"budget",
"mass-market",
"mass-premium",
"premium",
"luxury",
"to-be-defined"
]
},
"catalog_type": {
"type": "string",
"enum": [
"single-product",
"small-curated-catalog",
"broad-catalog",
"seasonal-catalog",
"mixed-catalog"
]
},
"brand_maturity": {
"type": "string",
"enum": [
"new",
"growing",
"established",
"legacy"
]
},
"operating_mode": {
"type": "string",
"enum": [
"draft-first",
"staging-first",
"production-managed"
]
},
"domain": {
"type": "string"
},
"secondary_domains": {
"type": "array",
"items": {
"type": "string"
}
},
"notes": {
"type": "string"
}
}
}

