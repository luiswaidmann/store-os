{
“$schema”: “https://json-schema.org/draft/2020-12/schema”,
“$id”: “https://example.com/schemas/collection-seo.schema.json”,
“title”: “Collection SEO Schema”,
“description”: “Schema for collection-level SEO and AEO planning inside store-os”,
“type”: “object”,
“additionalProperties”: false,
“required”: [
“primary_keyword”,
“secondary_keywords”,
“search_intent”,
“seo_title”,
“meta_description”,
“slug”,
“page_role”,
“internal_linking_targets”,
“answer_targets”
],
“properties”: {
“primary_keyword”: {
“type”: “string”,
“minLength”: 1
},
“secondary_keywords”: {
“type”: “array”,
“minItems”: 1,
“items”: {
“type”: “string”,
“minLength”: 1
}
},
“search_intent”: {
“type”: “string”,
“enum”: [
“informational”,
“commercial”,
“transactional”,
“comparison”,
“hybrid”
]
},
“seo_title”: {
“type”: “string”,
“minLength”: 1,
“maxLength”: 70
},
“meta_description”: {
“type”: “string”,
“minLength”: 1,
“maxLength”: 180
},
“slug”: {
“type”: “string”,
“minLength”: 1,
“pattern”: “^[a-z0-9-]+$”
},
“page_role”: {
“type”: “string”,
“enum”: [
“category-entry-page”,
“category-guide-page”,
“comparison-entry-page”,
“hybrid-category-page”
]
},
“internal_linking_targets”: {
“type”: “array”,
“minItems”: 1,
“items”: {
“type”: “object”,
“additionalProperties”: false,
“required”: [
“target_type”,
“target_reason”
],
“properties”: {
“target_type”: {
“type”: “string”,
“enum”: [
“sub-collection”,
“parent-collection”,
“product-page”,
“guide-page”,
“faq-page”,
“homepage”,
“blog-article”
]
},
“target_reason”: {
“type”: “string”,
“minLength”: 1
}
}
}
},
“answer_targets”: {
“type”: “array”,
“minItems”: 1,
“items”: {
“type”: “object”,
“additionalProperties”: false,
“required”: [
“question_type”,
“answer_goal”
],
“properties”: {
“question_type”: {
“type”: “string”,
“enum”: [
“what-is-this-category”,
“who-is-it-for”,
“how-to-choose”,
“what-are-the-differences”,
“best-for-use-case”,
“comparison”,
“compatibility”,
“care”,
“shipping”,
“returns”
]
},
“answer_goal”: {
“type”: “string”,
“minLength”: 1
}
}
}
},
“structured_data_targets”: {
“type”: “array”,
“items”: {
“type”: “string”,
“enum”: [
“breadcrumb”,
“faq”,
“item-list”
]
}
},
“canonical_strategy”: {
“type”: “string”,
“enum”: [
“self-canonical”,
“filter-aware”,
“platform-default”
]
},
“content_depth”: {
“type”: “string”,
“enum”: [
“light”,
“balanced”,
“deep”
]
},
“notes”: {
“type”: “string”
}
}
}

