{
"$schema": "https://json-schema.org/draft/2020-12/schema",
"$id": "https://example.com/schemas/page-content.schema.json",
"title": "Page Content Schema",
"description": "Schema for general store page content inside store-os",
"type": "object",
"additionalProperties": false,
"required": [
"page_title",
"page_type",
"page_goal",
"intro_text",
"body_sections",
"trust_elements",
"cta_direction"
],
"properties": {
"page_title": {
"type": "string",
"minLength": 1
},
"page_type": {
"type": "string",
"enum": [
"about-page",
"contact-page",
"shipping-page",
"returns-page",
"faq-page",
"guide-page",
"trust-page",
"landing-page",
"legal-support-page",
"generic-page"
]
},
"page_goal": {
"type": "string",
"enum": [
"inform",
"build-trust",
"support-conversion",
"educate",
"support-navigation",
"hybrid"
]
},
"page_subtitle": {
"type": "string"
},
"intro_text": {
"type": "string",
"minLength": 1
},
"body_sections": {
"type": "array",
"minItems": 1,
"items": {
"type": "object",
"additionalProperties": false,
"required": [
"section_title",
"section_purpose",
"section_text"
],
"properties": {
"section_title": {
"type": "string",
"minLength": 1
},
"section_purpose": {
"type": "string",
"enum": [
"explanation",
"trust",
"instruction",
"comparison",
"support",
"storytelling",
"hybrid"
]
},
"section_text": {
"type": "string",
"minLength": 1
}
}
}
},
"trust_elements": {
"type": "array",
"minItems": 1,
"items": {
"type": "string",
"minLength": 1
}
},
"faq_items": {
"type": "array",
"items": {
"type": "object",
"additionalProperties": false,
"required": [
"question",
"answer"
],
"properties": {
"question": {
"type": "string",
"minLength": 1
},
"answer": {
"type": "string",
"minLength": 1
}
}
}
},
"media_notes": {
"type": "array",
"items": {
"type": "string",
"minLength": 1
}
},
"internal_navigation_hints": {
"type": "array",
"items": {
"type": "string",
"minLength": 1
}
},
"cta_direction": {
"type": "object",
"additionalProperties": false,
"required": [
"primary_cta",
"cta_tone"
],
"properties": {
"primary_cta": {
"type": "string",
"enum": [
"none",
"contact-us",
"shop-now",
"explore-products",
"learn-more",
"mixed"
]
},
"cta_tone": {
"type": "string",
"enum": [
"subtle",
"balanced",
"assertive"
]
}
}
},
"notes": {
"type": "string"
}
}
}
