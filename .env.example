# store-os Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env for local reference ONLY.
# NEVER commit a .env file with real values to Git.
# Set these variables in the n8n process environment or via
# n8n Settings > Variables (recommended for n8n Cloud / managed installs).
#
# Phase 12 requires ALL variables listed under "Required" to be set.
# ─────────────────────────────────────────────────────────────────────────────


# ── Execution Environment ────────────────────────────────────────────────────

# Execution profile. Must be one of: dev | staging | production
# Controls safety check strictness, backup requirements, and publish gating.
STORE_OS_ENV=dev


# ── Filesystem Paths ─────────────────────────────────────────────────────────

# Root directory where project folders are created and artifacts are written.
# Must be writable by the n8n process. Must be on a persistent volume.
# Example: /data/store-os-projects
STORE_OS_PROJECT_ROOT=/data/store-os-projects

# Absolute path to the store-os schemas/ directory.
# n8n Code nodes load .schema.json files from this path for AJV validation.
# Example: /app/store-os/schemas
STORE_OS_AJV_SCHEMA_PATH=/app/store-os/schemas

# Root directory for project backup archives (used by backup-project workflow).
# Optional for dev. Required for staging and production.
# Example: /data/store-os-backups
STORE_OS_BACKUP_ROOT=/data/store-os-backups


# ── Credential Names (n8n Credential Store) ──────────────────────────────────
# These variables hold the NAMES of credentials stored in n8n's credential
# vault — NOT the credential values themselves.
# The actual API keys, tokens, and secrets must be configured in n8n.

# The exact name of the OpenAI credential as it appears in n8n's credential store.
# Used by all LLM synthesis workflows (build-market-intelligence and later).
# Example: "OpenAI store-os"
STORE_OS_OPENAI_CREDENTIAL_NAME=OpenAI store-os

# The exact name of the Shopify credential as it appears in n8n's credential store.
# Used by import-shopify-data. Must have read-only Admin API access.
# Example: "Shopify SuppliedTech Admin"
STORE_OS_SHOPIFY_CREDENTIAL_NAME=Shopify SuppliedTech Admin


# ── Shopify API Configuration ─────────────────────────────────────────────────

# The Shopify store's .myshopify.com domain (not a secret — publicly visible).
# Used to construct Shopify Admin API request URLs in import-shopify-data.
# Do NOT include https:// or trailing slash.
# Example: mystore.myshopify.com
STORE_OS_SHOPIFY_SHOP_URL=mystore.myshopify.com

# Shopify Admin API version. Must be pinned to a specific supported version.
# Never use "unstable" or "latest". Update deliberately when Shopify deprecates a version.
# Example: 2025-01
STORE_OS_SHOPIFY_API_VERSION=2025-01


# ── LLM Configuration ────────────────────────────────────────────────────────

# The OpenAI model identifier for LLM synthesis nodes.
# Must be a model available through STORE_OS_OPENAI_CREDENTIAL_NAME.
# Must support JSON mode (response_format: json_object) or structured output.
# This is not a secret. Recommended: gpt-4o for production, gpt-4o-mini for dev.
STORE_OS_LLM_MODEL=gpt-4o-mini


# ── n8n Deploy Automation ────────────────────────────────────────────────────
# Used by scripts/deploy-workflow.js to push repo workflow JSON to n8n via API.
# NOT used by n8n itself — these are local dev/ops variables only.

# Base URL of your n8n instance. No trailing slash.
# Example: https://your-instance.app.n8n.cloud
N8N_BASE_URL=https://your-instance.app.n8n.cloud

# n8n API key for deploy automation.
# Create at: n8n Settings > API > Create API Key
# NEVER commit a real API key. Keep this in .env only.
N8N_API_KEY=your-n8n-api-key-here


# ─────────────────────────────────────────────────────────────────────────────
# n8n Workflow Setup Notes
# ─────────────────────────────────────────────────────────────────────────────
#
# Automated deploy (recommended):
#   node scripts/deploy-workflow.js orchestrate-phase1
#
#   Requires N8N_BASE_URL and N8N_API_KEY set above.
#   Workflow IDs are read from workflows/n8n/workflow-ids.json.
#   REPLACE_WITH_* placeholders are substituted automatically.
#
# Manual setup (if not using the deploy script):
#
# 1. Configure your Shopify credential in n8n:
#    n8n Settings > Credentials > New > Shopify API
#    Set the Access Token for your store.
#    Name it exactly as STORE_OS_SHOPIFY_CREDENTIAL_NAME above.
#
# 2. Configure your OpenAI credential in n8n:
#    n8n Settings > Credentials > New > OpenAI API
#    Set your OpenAI API key.
#    Name it exactly as STORE_OS_OPENAI_CREDENTIAL_NAME above.
#
# 3. Update import-shopify-data.n8n.json:
#    Replace REPLACE_WITH_N8N_SHOPIFY_CREDENTIAL_ID with the actual
#    numeric ID of the Shopify credential from step 1.
#    (Find the ID in the URL when editing the credential in n8n.)
#
# 4. Update orchestrate-phase1.n8n.json:
#    Replace REPLACE_WITH_*_WORKFLOW_ID placeholders with the actual
#    n8n workflow IDs. See workflows/n8n/workflow-ids.json for this instance.
#
# 5. Create STORE_OS_PROJECT_ROOT directory:
#    mkdir -p /data/store-os-projects
#    Ensure it is writable by the n8n process user.
